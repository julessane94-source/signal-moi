# Exemple de variables d'environnement pour le backend
# Ne pas committer de vraies clefs. Remplir dans Render / Vercel / local .env

# Database: soit `DATABASE_URL` (préféré), soit les variables séparées ci-dessous
# Exemple DATABASE_URL postgres: postgres://user:password@host:5432/dbname
DATABASE_URL=
DB_DIALECT=postgres
DB_HOST=localhost
DB_PORT=5432
DB_NAME=signal_moi_db
DB_USER=root
DB_PASSWORD=

# JWT
JWT_SECRET=change_me

# Frontend
FRONTEND_URL=http://localhost:3000

# SMTP (email)
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASS=
SMTP_FROM="Signal-Moi <no-reply@example.org>"

# File storage (S3).
# If USE_S3=true, uploads will be stored in the S3 bucket; otherwise local `uploads/`.
USE_S3=false
S3_BUCKET=
S3_REGION=
# Support both variable names: `AWS_ACCESS_KEY_ID`/`AWS_SECRET_ACCESS_KEY` (preferred)
# or legacy `S3_ACCESS_KEY_ID`/`S3_SECRET_ACCESS_KEY`.
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=

# Socket / realtime
PORT=5000
# Database (use DATABASE_URL in production)
DB_DIALECT=postgres
DB_HOST=localhost
DB_PORT=5432
DB_NAME=signal_moi_db
DB_USER=postgres
DB_PASSWORD=changeme

# JWT
JWT_SECRET=change_this_secret

# Frontend URL (utilisé pour les emails / redirects)
FRONTEND_URL=http://localhost:3000

# SMTP (email)
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASS=
SMTP_FROM="Signal-Moi <no-reply@example.com>"

# File uploads
USE_S3=false
S3_BUCKET=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_REGION=
ALLOWED_FILE_TYPES=image/jpeg,image/png,image/webp,image/gif,audio/mpeg,audio/wav,video/mp4
MAX_FILE_SIZE=10485760
MAX_FILE_COUNT=5

# Other
PORT=5000
NODE_ENV=development