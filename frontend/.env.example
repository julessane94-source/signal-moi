# Exemple d'env pour le frontend Next.js
# Remplacez les valeurs par vos URLs/clefs de production

# URL publique de l'API (sans /api à la fin si vous utilisez rewrites)
NEXT_PUBLIC_API_URL=https://your-backend-render-url/api

# WebSocket (si utilisé)
NEXT_PUBLIC_SOCKET_URL=wss://your-backend-render-url

# Connexion Google
NEXT_PUBLIC_GOOGLE_CLIENT_ID=

# Token pour les services de cartographie (Leaflet/Mapbox si nécessaire)
NEXT_PUBLIC_MAPBOX_TOKEN=

# Environnement
NODE_ENV=production
